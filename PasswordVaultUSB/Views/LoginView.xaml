<Window
    x:Class="PasswordVaultUSB.Views.LoginView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PasswordVaultUSB.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:PasswordVaultUSB.ViewModels"
    Title="Autorization"
    Width="800"
    Height="600"
    MinWidth="450"
    MinHeight="350"
    Background="{StaticResource BackgroundColor}"
    FontFamily="Segoe UI"
    Style="{StaticResource WindowStyle}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Window.DataContext>
        <vm:LoginViewModel />
    </Window.DataContext>

    <Window.InputBindings>
        <KeyBinding
            Key="Enter"
            Command="{Binding LoginCommand}"
            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" />
    </Window.InputBindings>

    <Grid>
        <Border
            Width="400"
            Padding="30"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="White"
            CornerRadius="10">
            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="20"
                    Opacity="0.4"
                    ShadowDepth="5"
                    Color="#CCCCCC" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="20" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="15" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" HorizontalAlignment="Center">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="28"
                        FontWeight="Bold"
                        Foreground="#333333"
                        Text="Password Vault" />

                    <TextBlock
                        Margin="0,5,0,0"
                        HorizontalAlignment="Center"
                        FontSize="14"
                        Foreground="#777777"
                        Text="Login in to the system" />
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <TextBlock
                        Margin="0,0,0,5"
                        FontWeight="SemiBold"
                        Foreground="#555555"
                        Text="Username" />
                    <Border
                        Height="45"
                        BorderBrush="#DDDDDD"
                        BorderThickness="1"
                        CornerRadius="5">
                        <TextBox
                            Padding="10,0"
                            VerticalContentAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            FontSize="16"
                            Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />
                    </Border>
                    <TextBlock
                        Margin="2,5,0,0"
                        HorizontalAlignment="Left"
                        FontSize="13"
                        Foreground="#D8000C"
                        Text="{Binding UsernameError}"
                        TextWrapping="Wrap"
                        Visibility="{Binding HasUsernameError, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>


                <StackPanel Grid.Row="4">
                    <TextBlock
                        Margin="0,0,0,5"
                        FontWeight="SemiBold"
                        Foreground="#555555"
                        Text="Password" />
                    <Border
                        Height="45"
                        BorderBrush="#DDDDDD"
                        BorderThickness="1"
                        CornerRadius="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="40" />
                            </Grid.ColumnDefinitions>

                            <PasswordBox
                                x:Name="PasswordInput"
                                Grid.Column="0"
                                Padding="10,0"
                                VerticalContentAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                FontFamily="Consolas"
                                FontSize="18">
                                <PasswordBox.Style>
                                    <Style TargetType="PasswordBox">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPasswordVisible}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </PasswordBox.Style>
                            </PasswordBox>

                            <TextBox
                                Grid.Column="0"
                                Padding="10,0"
                                VerticalContentAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                FontFamily="Consolas"
                                FontSize="18"
                                Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPasswordVisible}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <Button
                                Grid.Column="1"
                                Background="Transparent"
                                BorderThickness="0"
                                Command="{Binding TogglePasswordVisibilityCommand}"
                                Cursor="Hand">
                                <Viewbox Width="20" Height="20">
                                    <Image Opacity="0.6">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Source" Value="/Resources/visibility.png" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPasswordVisible}" Value="True">
                                                        <Setter Property="Source" Value="/Resources/visibility_off.png" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Viewbox>
                            </Button>
                        </Grid>
                    </Border>
                    <TextBlock
                        Margin="2,5,0,10"
                        HorizontalAlignment="Left"
                        FontSize="13"
                        Foreground="#D8000C"
                        Text="{Binding PasswordError}"
                        TextWrapping="Wrap"
                        Visibility="{Binding HasPasswordError, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>

                <Button
                    Grid.Row="6"
                    Width="200"
                    Height="45"
                    Command="{Binding LoginCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Content="Log in"
                    Style="{StaticResource ModernButtonStyle}" />

                <Button
                    Grid.Row="7"
                    Margin="0,15,0,0"
                    HorizontalAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0"
                    Command="{Binding NavigateToRegisterCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Content="Don't have an account? Register"
                    Cursor="Hand"
                    Foreground="#0078D7" />
            </Grid>
        </Border>
    </Grid>
</Window>
