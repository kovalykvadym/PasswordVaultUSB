<Window
    x:Class="PasswordVaultUSB.Views.MainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:PasswordVaultUSB.ViewModels"
    Title="Password Vault"
    Width="900"
    Height="600"
    PreviewKeyDown="Window_PreviewInput"
    PreviewMouseMove="Window_PreviewInput"
    Style="{StaticResource WindowStyle}"
    WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid Background="{StaticResource WindowBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SidebarBackgroundBrush}">
            <StackPanel>
                <TextBlock
                    Margin="20,30,0,40"
                    FontSize="28"
                    FontWeight="Bold"
                    Foreground="White"
                    Text="PVault" />

                <Button
                    Height="40"
                    Margin="15,0,15,30"
                    Command="{Binding AddPasswordCommand}"
                    Content="+ Add Password"
                    Style="{StaticResource ModernButtonStyle}" />

                <TextBlock
                    Margin="20,0,0,10"
                    FontSize="12"
                    FontWeight="Bold"
                    Foreground="#666"
                    Text="MAIN MENU" />

                <Button
                    x:Name="MyPasswordsButton"
                    Click="MenuButton_Click"
                    Command="{Binding ChangeMenuCommand}"
                    CommandParameter="MyPasswords"
                    Content="My Passwords"
                    Style="{StaticResource MenuButtonStyle}" />

                <Button
                    x:Name="FavoritesButton"
                    Click="MenuButton_Click"
                    Command="{Binding ChangeMenuCommand}"
                    CommandParameter="Favorites"
                    Content="Favorites"
                    Style="{StaticResource MenuButtonStyle}" />

                <Button
                    x:Name="UsbButton"
                    Click="MenuButton_Click"
                    Command="{Binding ChangeMenuCommand}"
                    CommandParameter="Usb"
                    Content="USB Security Key"
                    Style="{StaticResource MenuButtonStyle}" />

                <TextBlock
                    Margin="20,20,0,10"
                    FontSize="12"
                    FontWeight="Bold"
                    Foreground="#666"
                    Text="SYSTEM" />

                <Button
                    Command="{Binding OpenSettingsCommand}"
                    Content="Settings"
                    Style="{StaticResource MenuButtonStyle}" />
                <Button
                    Command="{Binding LockVaultCommand}"
                    Content="Lock Vault"
                    Style="{StaticResource MenuButtonStyle}" />
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid
                Grid.Row="0"
                Margin="0,0,0,20"
                Visibility="{Binding IsPasswordsVisible, Converter={StaticResource BoolToVis}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="250" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock
                        FontSize="26"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Text="My Passwords" />
                    <TextBlock
                        FontSize="14"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="Manage and secure your credentials" />
                </StackPanel>

                <Border
                    Grid.Column="1"
                    Height="35"
                    Padding="10,0"
                    Style="{StaticResource InputBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Image
                            Width="16"
                            Height="16"
                            Margin="0,0,5,0"
                            Opacity="0.5"
                            Source="/Resources/search.png" />
                        <TextBox
                            Grid.Column="1"
                            Style="{StaticResource BaseInputStyle}"
                            Tag="Search..."
                            Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </Border>
            </Grid>

            <StackPanel
                x:Name="ChangePasswordPanel"
                Grid.Row="1"
                Margin="0,0,0,20"
                Visibility="{Binding IsChangePasswordVisible, Converter={StaticResource BoolToVis}}">

                <TextBlock
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="#333"
                    Text="Change master password" />

                <StackPanel Margin="0,10,0,10">
                    <TextBlock
                        Margin="0,0,0,5"
                        FontWeight="SemiBold"
                        Foreground="#666"
                        Text="Current password" />
                    <Border Height="36" Style="{StaticResource InputBorderStyle}">
                        <PasswordBox
                            x:Name="CurrentPasswordInput"
                            FontSize="14"
                            Style="{StaticResource BasePasswordBoxStyle}" />
                    </Border>
                </StackPanel>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock
                        Margin="0,0,0,5"
                        FontWeight="SemiBold"
                        Foreground="#666"
                        Text="New password" />
                    <Border Height="36" Style="{StaticResource InputBorderStyle}">
                        <PasswordBox
                            x:Name="NewPasswordInput"
                            FontSize="14"
                            Style="{StaticResource BasePasswordBoxStyle}" />
                    </Border>
                </StackPanel>

                <StackPanel Margin="0,0,0,15">
                    <TextBlock
                        Margin="0,0,0,5"
                        FontWeight="SemiBold"
                        Foreground="#666"
                        Text="Confirm new password" />
                    <Border Height="36" Style="{StaticResource InputBorderStyle}">
                        <PasswordBox
                            x:Name="ConfirmPasswordInput"
                            FontSize="14"
                            Style="{StaticResource BasePasswordBoxStyle}" />
                    </Border>
                </StackPanel>

                <Button
                    Width="140"
                    Height="34"
                    HorizontalAlignment="Right"
                    Command="{Binding UpdateMasterPasswordCommand}"
                    CommandParameter="{Binding ElementName=ChangePasswordPanel}"
                    Content="Update"
                    Style="{StaticResource ModernButtonStyle}" />

                <Separator Margin="0,15,0,10" />

                <TextBlock
                    Margin="0,0,0,5"
                    FontWeight="SemiBold"
                    Foreground="#666"
                    Text="Activity log" />
                <Border
                    Height="150"
                    Background="#FAFAFA"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    CornerRadius="6">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ActivityLog}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        Margin="6,2"
                                        FontSize="13"
                                        Foreground="#444"
                                        Text="{Binding}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </StackPanel>

            <DataGrid
                Grid.Row="2"
                AutoGenerateColumns="False"
                Background="White"
                BorderThickness="0"
                CanUserAddRows="False"
                GridLinesVisibility="Horizontal"
                IsReadOnly="True"
                ItemsSource="{Binding Passwords}"
                RowHeight="40"
                Visibility="{Binding IsPasswordsVisible, Converter={StaticResource BoolToVis}}">

                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding Service}"
                        Header="Service">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding Login}"
                        Header="Login">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Width="150" Header="Password">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                                    <TextBlock
                                        Width="100"
                                        FontFamily="Consolas"
                                        Text="{Binding DisplayPassword}"
                                        TextAlignment="Center" />
                                    <Button
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Command="{Binding DataContext.ToggleShowPasswordCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Cursor="Hand">
                                        <Image
                                            Width="18"
                                            Opacity="{Binding EyeIconOpacity}"
                                            Source="/Resources/visibility.png" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding Url}"
                        Foreground="Blue"
                        Header="Website">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Width="120" Header="Actions">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                    <Button
                                        Margin="0,0,5,0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Command="{Binding DataContext.CopyPasswordCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Cursor="Hand">
                                        <Image Width="18" Source="/Resources/copy.png" />
                                    </Button>
                                    <Button
                                        Margin="0,0,5,0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Command="{Binding DataContext.EditPasswordCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Cursor="Hand">
                                        <Image Width="18" Source="/Resources/edit.png" />
                                    </Button>
                                    <Button
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Command="{Binding DataContext.DeletePasswordCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Cursor="Hand">
                                        <Image Width="18" Source="/Resources/trash_can.png" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Width="50" Header="Fav">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button
                                    HorizontalAlignment="Center"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    Cursor="Hand">
                                    <Image
                                        Width="18"
                                        Opacity="{Binding FavoriteIconOpacity}"
                                        Source="/Resources/star.png" />
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>